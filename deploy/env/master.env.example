NODE_ENV=production
BACKEND_PORT=3000
DATABASE_URL=postgres://newdomofon:CHANGE_DB_PASSWORD@127.0.0.1:5432/newdomofon_video
JWT_SECRET=CHANGE_TO_32_PLUS_RANDOM_CHARS
ADMIN_LOGIN=admin
ADMIN_PASSWORD=CHANGE_TO_STRONG_PASSWORD
CORS_ORIGIN=https://video-master.example.com
TRUST_PROXY=true

# Allows new video nodes to self-register at /api/node-agent/register.
# Keep empty if nodes are created manually in the admin UI.
NODE_REGISTRATION_TOKEN=CHANGE_TO_RANDOM_NODE_REGISTRATION_TOKEN

# Internal ONVIF/event ingest secret shared by master and trusted nodes.
INTERNAL_DVR_SECRET=CHANGE_TO_RANDOM_INTERNAL_SECRET

# Event timeline defaults. Passive ONVIF state snapshots such as false/inactive
# are hidden from public timeline responses unless include_passive=1 is requested.
PUBLIC_EVENTS_INCLUDE_PASSIVE=false

# Store ONVIF state transitions only. Repeated same-state snapshots are skipped.
ONVIF_EVENT_SUPPRESS_REPEATED_STATE=true

# Local standalone DVR fallback. In a pure master this can stay local-only.
DVR_ENGINE_URL=http://127.0.0.1:3010
MEDIA_PUBLIC_BASE_URL=/api/media
PLAYBACK_TOKEN_TTL_SECONDS=900
