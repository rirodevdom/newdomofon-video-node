# NewDomofon Video Node production environment.
# Рабочая копия: /etc/newdomofon-video/app.env
# Полный справочник: docs/ENVIRONMENT.md

# Режим Node.js. На production оставлять production.
NODE_ENV=production

# Роль DVR engine. На отдельной video node всегда node.
DVR_ENGINE_ROLE=node

# Локальный HTTP-порт DVR engine. Master обычно обращается к нему по private network.
DVR_ENGINE_PORT=3010

# Корень live-файлов и локального архива. Желательно отдельная mountpoint.
DVR_ROOT=/var/lib/newdomofon-video/dvr

# Полный путь к FFmpeg.
FFMPEG_PATH=/usr/bin/ffmpeg

# Целевая длительность одного HLS/архивного segment в секундах.
SEGMENT_DURATION=4

# Число segment в live playlist.
LIVE_WINDOW=8

# Интервал повторного получения camera config с master, секунд.
CAMERA_RELOAD_SECONDS=20

# Интервал штатной retention-очистки архива, минут.
CLEANUP_INTERVAL_MINUTES=60

# Максимальная длительность одного MP4 export, секунд.
MAX_EXPORT_SECONDS=3600

# Сколько ждать появления live playlist перед ошибкой, миллисекунд.
DVR_LIVE_PLAYLIST_WAIT_MS=10000

# -----------------------------------------------------------------------------
# Ручная регистрация node на master
# -----------------------------------------------------------------------------
# Эти значения выбираются при развёртывании node. Затем их нужно посимвольно
# перенести в Администрирование -> Ноды -> Создать node на master.
# Master не генерирует UUID, agent token или media secret.

# Базовый URL master без завершающего slash.
DVR_MASTER_URL=https://video-master.example.com

# UUID этой node. Сгенерировать: uuidgen
DVR_NODE_ID=CHOOSE_A_UUID_FOR_THIS_NODE

# Agent token heartbeat/config/commands. 16-512 символов A-Z a-z 0-9 . _ ~ -
# Рекомендуемая генерация: openssl rand -hex 32
DVR_NODE_TOKEN=CHOOSE_A_SAFE_AGENT_TOKEN_OF_AT_LEAST_16_CHARACTERS

# Общий secret для внутренних media/event tokens. Те же требования, что у token.
# Рекомендуемая генерация: openssl rand -hex 32
DVR_NODE_MEDIA_SECRET=CHOOSE_A_SAFE_MEDIA_SECRET_OF_AT_LEAST_16_CHARACTERS

# URL node, который может использоваться в публичных media-ссылках.
DVR_NODE_PUBLIC_BASE_URL=https://video-node-1.example.com

# Private URL, по которому master напрямую обращается к DVR engine.
DVR_NODE_INTERNAL_URL=http://10.0.10.11:3010

# Обязательная проверка внутреннего media token. В production оставлять true.
DVR_REQUIRE_MEDIA_TOKEN=true

# Разрешённый browser origin. Обычно равен DVR_MASTER_URL.
DVR_CORS_ORIGIN=https://video-master.example.com

# -----------------------------------------------------------------------------
# DASH и JPEG snapshot
# -----------------------------------------------------------------------------

# Длительность DASH segment, секунд.
DVR_DASH_SEGMENT_SECONDS=2

# Число основных segment в DASH manifest.
DVR_DASH_WINDOW_SIZE=8

# Дополнительный запас старых DASH segment.
DVR_DASH_EXTRA_WINDOW_SIZE=4

# Максимальное ожидание готовности on-demand DASH, миллисекунд.
DVR_DASH_READY_TIMEOUT_MS=15000

# Остановить DASH-процесс после простоя без клиентов, миллисекунд.
DVR_DASH_IDLE_MS=300000

# Время кэширования JPEG snapshot, миллисекунд.
DVR_SNAPSHOT_CACHE_MS=3000

# FFmpeg JPEG quality: меньшее значение = лучше качество и больше файл.
DVR_SNAPSHOT_JPEG_QUALITY=3

# -----------------------------------------------------------------------------
# Локальные события
# -----------------------------------------------------------------------------

# Путь к SQLite database событий.
DVR_EVENT_DB=/var/lib/newdomofon-video/events/events.sqlite3

# Retention событий, суток.
DVR_EVENT_RETENTION_DAYS=30

# Интервал очистки старых событий, минут.
DVR_EVENT_CLEANUP_INTERVAL_MINUTES=60

# Максимальный диапазон одного event query, секунд.
DVR_EVENT_QUERY_MAX_SECONDS=2678400

# Сохранять исходный ONVIF/Hikvision payload. Обычно false.
DVR_EVENT_STORE_RAW_PAYLOAD=false

# Включить ONVIF PullPoint/event collector.
ONVIF_EVENTS_ENABLED=true

# Timeout ONVIF event request, миллисекунд.
ONVIF_EVENTS_REQUEST_TIMEOUT_MS=15000

# Включить Hikvision alertStream collector там, где он требуется.
DVR_HIKVISION_EVENTS_ENABLED=false

# Включить software motion detection через FFmpeg. Увеличивает нагрузку CPU.
VIDEO_MOTION_ENABLED=false

# -----------------------------------------------------------------------------
# Синхронизация событий с реально существующим локальным архивом
# -----------------------------------------------------------------------------

# Установить/использовать archive-event reconciler.
DVR_ARCHIVE_EVENT_SYNC_ENABLED=true

# false = только отчёт; true = удалять orphan events. Начинайте с false.
DVR_ARCHIVE_EVENT_SYNC_APPLY=false

# Не проверять слишком свежие archive-hour каталоги, минут.
DVR_ARCHIVE_EVENT_SYNC_MIN_AGE_MINUTES=120

# Максимум camera-hour buckets за один запуск.
DVR_ARCHIVE_EVENT_SYNC_MAX_HOURS_PER_RUN=1000

# Timeout получения camera config с master, миллисекунд.
DVR_ARCHIVE_EVENT_SYNC_MASTER_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Disk guard
# -----------------------------------------------------------------------------
# Guard запускает аварийную очистку ниже max(byte threshold, percent threshold)
# и возобновляет запись только после достижения resume thresholds.

# Минимум свободных байт на archive filesystem до аварийной очистки: 10 GiB.
DVR_DISK_MIN_FREE_BYTES=10737418240

# Минимум свободного места archive filesystem, процентов.
DVR_DISK_MIN_FREE_PERCENT=10

# Byte-порог возобновления записи: 15 GiB.
DVR_DISK_RESUME_FREE_BYTES=16106127360

# Процентный порог возобновления записи.
DVR_DISK_RESUME_FREE_PERCENT=15

# Минимум свободных inode до аварийного состояния.
DVR_DISK_MIN_FREE_INODES_PERCENT=5

# Порог inode для возобновления.
DVR_DISK_RESUME_FREE_INODES_PERCENT=8

# Минимум свободных байт на system filesystem с SQLite/logs/tmp: 2 GiB.
DVR_SYSTEM_MIN_FREE_BYTES=2147483648

# Минимум свободного места system filesystem, процентов.
DVR_SYSTEM_MIN_FREE_PERCENT=5

# Byte-порог восстановления system filesystem: 4 GiB.
DVR_SYSTEM_RESUME_FREE_BYTES=4294967296

# Процентный порог восстановления system filesystem.
DVR_SYSTEM_RESUME_FREE_PERCENT=10

# Не удалять archive-hour каталоги моложе этого возраста, минут.
DVR_DISK_MIN_ARCHIVE_AGE_MINUTES=60

# Максимум удаляемых hour-каталогов за один запуск guard.
DVR_DISK_MAX_DELETE_DIRS_PER_RUN=500

# Возраст stale export/device-archive temp, после которого их можно удалить.
DVR_DISK_STALE_TMP_MINUTES=60

# true = DVR_ROOT обязан быть отдельной mountpoint; защищает root disk при
# пропавшем архивном диске. false допустимо только при осознанном хранении на /.
DVR_DISK_REQUIRE_MOUNTPOINT=false

# -----------------------------------------------------------------------------
# Hikvision/NVR device archive playback
# -----------------------------------------------------------------------------

# Максимальный диапазон одной device-archive playback-сессии, секунд.
DVR_DEVICE_ARCHIVE_MAX_RANGE_SECONDS=300

# Минимальная длительность playback, секунд.
DVR_DEVICE_ARCHIVE_MIN_PLAYBACK_SECONDS=30

# Размер переиспользуемого session window, секунд.
DVR_DEVICE_ARCHIVE_SESSION_WINDOW_SECONDS=300

# Шаг выравнивания начала session для reuse, секунд.
DVR_DEVICE_ARCHIVE_SESSION_ALIGN_SECONDS=30

# Одновременный лимит playback sessions на одно устройство.
DVR_DEVICE_ARCHIVE_MAX_SESSIONS_PER_DEVICE=1

# Максимальное ожидание подготовки HLS session, миллисекунд.
DVR_DEVICE_ARCHIVE_PREPARE_WAIT_MS=25000

# Timeout первого segment, миллисекунд.
DVR_DEVICE_ARCHIVE_FIRST_SEGMENT_TIMEOUT_MS=20000

# Сколько хранить idle session, миллисекунд.
DVR_DEVICE_ARCHIVE_KEEP_MS=900000

# Время кэширования Hikvision archive search, миллисекунд.
DVR_HIKVISION_ARCHIVE_SEARCH_CACHE_MS=60000

# Timeout Hikvision archive search, миллисекунд.
DVR_HIKVISION_ARCHIVE_SEARCH_TIMEOUT_MS=15000

# Число записей на страницу поиска.
DVR_HIKVISION_ARCHIVE_SEARCH_PAGE_SIZE=64

# Максимум страниц одного поиска.
DVR_HIKVISION_ARCHIVE_SEARCH_MAX_PAGES=120

# 0 = не запускать дополнительный fallback, если основной search пуст.
DVR_HIKVISION_ARCHIVE_FALLBACK_ON_EMPTY=0
