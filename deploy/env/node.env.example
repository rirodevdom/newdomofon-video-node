NODE_ENV=production
DVR_ENGINE_PORT=3010
DVR_ROOT=/var/lib/newdomofon-video/dvr
FFMPEG_PATH=/usr/bin/ffmpeg
SEGMENT_DURATION=4
LIVE_WINDOW=8
CAMERA_RELOAD_SECONDS=20
CLEANUP_INTERVAL_MINUTES=60
MAX_EXPORT_SECONDS=3600

# Master connection. The node calls master outbound and does not need direct DB access.
DVR_MASTER_URL=https://video-master.example.com
DVR_NODE_ID=PASTE_NODE_ID_FROM_MASTER
DVR_NODE_TOKEN=PASTE_AGENT_TOKEN_FROM_MASTER

# Public URL used by clients when master returns playback URLs for this node.
DVR_NODE_PUBLIC_BASE_URL=https://video-node-1.example.com

# Optional URL master can use for status checks if it has private network access.
DVR_NODE_INTERNAL_URL=http://127.0.0.1:3010

# Optional bootstrap copy. In node mode the DVR also receives media_secret from master config.
DVR_NODE_MEDIA_SECRET=PASTE_MEDIA_SECRET_FROM_MASTER
DVR_REQUIRE_MEDIA_TOKEN=true
DVR_CORS_ORIGIN=https://video-master.example.com

# Shared secret for ONVIF events posted back to master.
BACKEND_INTERNAL_URL=https://video-master.example.com
INTERNAL_DVR_SECRET=CHANGE_TO_RANDOM_INTERNAL_SECRET

# Hikvision/NVR device archive playback sessions.
# Device archive is prepared as a short reusable HLS session instead of starting
# a new RTSP playback process for every timeline seek.
DVR_DEVICE_ARCHIVE_MAX_RANGE_SECONDS=300
DVR_DEVICE_ARCHIVE_MIN_PLAYBACK_SECONDS=30
DVR_DEVICE_ARCHIVE_SESSION_WINDOW_SECONDS=300
DVR_DEVICE_ARCHIVE_SESSION_ALIGN_SECONDS=30
DVR_DEVICE_ARCHIVE_MAX_SESSIONS_PER_DEVICE=1
DVR_DEVICE_ARCHIVE_PREPARE_WAIT_MS=25000
DVR_DEVICE_ARCHIVE_FIRST_SEGMENT_TIMEOUT_MS=20000
DVR_DEVICE_ARCHIVE_KEEP_MS=900000
DVR_HIKVISION_ARCHIVE_SEARCH_CACHE_MS=60000
DVR_HIKVISION_ARCHIVE_SEARCH_TIMEOUT_MS=15000
DVR_HIKVISION_ARCHIVE_SEARCH_PAGE_SIZE=64
DVR_HIKVISION_ARCHIVE_SEARCH_MAX_PAGES=120
DVR_HIKVISION_ARCHIVE_FALLBACK_ON_EMPTY=0
